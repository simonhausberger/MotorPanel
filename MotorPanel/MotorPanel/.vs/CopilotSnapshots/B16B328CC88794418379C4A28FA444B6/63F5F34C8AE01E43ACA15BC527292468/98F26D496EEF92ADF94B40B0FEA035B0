                txtbTargetSpeed.IsEnabled = false;
                txtbTargetIq.IsEnabled = true;

                
            }
            else     // speed-Regelung
            {
                LogEvent("switched to speed control (FOC keeps activated)");
                SwitchBlockFoc.IsEnabled = true;
                txtbTargetSpeed.IsEnabled = true;
                txtbTargetIq.IsEnabled = false;

                
            }

            SendControlPacket();
        }

