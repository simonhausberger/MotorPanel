<Window x:Class="MotorPanel.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Motor Panel Setup"
        Height="330"
        Width="700"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Device:" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <TextBox x:Name="TbDevice" Grid.Row="0" Grid.Column="1" Margin="0,0,10,10" Text="PSC3XXF_TM"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="ELF path:" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <TextBox x:Name="TbElfPath" Grid.Row="1" Grid.Column="1" Margin="0,0,10,10"/>
        <Button Grid.Row="1" Grid.Column="2" Content="Browse..." Click="BrowseElf_Click" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="JLink.exe path:" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <TextBox x:Name="TbJLinkPath" Grid.Row="2" Grid.Column="1" Margin="0,0,10,10"/>
        <Button Grid.Row="2" Grid.Column="2" Content="Browse..." Click="BrowseJLink_Click" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Speed kHz:" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <TextBox x:Name="TbSpeed" Grid.Row="3" Grid.Column="1" Margin="0,0,10,10" Text="1000"/>

        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
            <Button Content="Blockkommutation" Background="Beige" Width="170" Click="OpenMotorPanelBLOCK_Click" Height="114"/>
            <Button Content="FOC" Width="170" Background="Beige" Click="OpenMotorPanelFOC_Click"/>
        </StackPanel>
    </Grid>
</Window>